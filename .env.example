# Compose deployment defaults for PalPanel Lite.
# Copy this file to .env before running docker compose from the repository root.

# Full image reference used by the root docker-compose.yml.
PALPANEL_IMAGE=ghcr.io/ksamni/palpanel-lite:latest

# Used by deploy/compose.yaml when building locally.
PALPANEL_VERSION=local

# Host port bound to 127.0.0.1. Keep a reverse proxy in front for remote access.
PALPANEL_PORT=8080

# Palworld game UDP port. Keep this aligned with the panel launch/config game port.
PALWORLD_GAME_HOST_PORT=8211
PALWORLD_GAME_PORT=8211

# Relative paths here are resolved from the root docker-compose.yml.
PALPANEL_DATA_DIR=./data
PALPANEL_SERVER_DIR=./PalServer

# SteamCMD is bundled in the image, but its mutable runtime files live under /data.
PALPANEL_STEAMCMD_DIR=/data/steamcmd

# Optional Steam login for Workshop items that anonymous SteamCMD cannot download.
# Use a Steam account that owns Palworld. Keep real credentials only in local .env.
PALPANEL_STEAMCMD_USERNAME=
PALPANEL_STEAMCMD_PASSWORD=

# Initial persisted PalServer path for a fresh panel database.
PALPANEL_DEFAULT_PAL_SERVER_PATH=/palserver

# Container process user. The image entrypoint repairs /data and /palserver
# ownership to this UID/GID, then runs the panel as this user.
PALPANEL_UID=10001
PALPANEL_GID=10001
PALPANEL_FIX_OWNERSHIP=true

# Timezone used by the container. Daily scheduled actions (HH:MM) and the
# panel clock follow this timezone. Defaults to Asia/Shanghai (UTC+8).
TZ=Asia/Shanghai
