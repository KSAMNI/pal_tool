{
  "name": "palpanel-lite-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "prebuild": "node -e \"const fs=require('fs'); fs.rmSync('../internal/frontend/dist/assets',{recursive:true,force:true}); fs.rmSync('../internal/frontend/dist/index.html',{force:true})\"",
    "build": "vue-tsc --noEmit -p tsconfig.json && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "lucide-vue-next": "^0.468.0",
    "naive-ui": "^2.40.3",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}
